{
	"name": "maplibre-copc-layer",
	"version": "1.0.0",
	"description": "A library for loading and rendering Cloud-Optimized Point Cloud (COPC) data in MapLibre GL JS",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build && cp src/worker/laz-perf.wasm demo/assets",
		"build:lib": "tsc --project tsconfig.lib.json",
		"preview": "vite preview"
	},
	"keywords": [
		"copc",
		"point-cloud",
		"maplibre",
		"three.js",
		"webgl",
		"geospatial",
		"lidar"
	],
	"author": "kanahiro",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/kanahiro/copc-viewer.git"
	},
	"devDependencies": {
		"@types/proj4": "^2.5.6",
		"@types/three": "^0.173.0",
		"lil-gui": "^0.20.0",
		"maplibre-gl": "^5.1.1",
		"proj4": "^2.15.0",
		"proj4js": "^10.0.0",
		"three": "^0.173.0",
		"typescript": "~5.7.2",
		"vite": "^6.1.0"
	},
	"dependencies": {
		"copc": "^0.0.8",
		"laz-perf": "^0.0.7",
		"maplibre-gl-gsi-terrain": "^2.2.0"
	}
}
